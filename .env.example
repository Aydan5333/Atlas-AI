# Atlas local environment example
# Copy this file to .env and fill in your real values locally.
# Never commit real API keys, tokens, passkeys, passwords, or private family data.

SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Optional future values
ATLAS_ENV=development
ATLAS_PUBLIC_APP_NAME=Atlas
ATLAS_PUBLIC_ORG_NAME=TSC
